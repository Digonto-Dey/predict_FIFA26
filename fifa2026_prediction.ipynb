    "def run_scenario_analysis(team_name, rating_shock, simulator_obj, groups, initial_states):\n"
    "    print(f\"\\n--- Running Scenario Analysis: {team_name} with rating shock {rating_shock} ---\")\n"
    "    shock_states = copy.deepcopy(initial_states)\n"
    "    if team_name in shock_states:\n"
    "        shock_states[team_name]['rating'] += rating_shock\n"
    "        print(f\"Adjusted rating: {initial_states[team_name]['rating']:.1f} -> {shock_states[team_name]['rating']:.1f}\")\n"
    "    else:\n"
    "        print(f\"Error: {team_name} not found!\")\n"
    "        return None\n"
    "        \n"
    "    sim_results_shock = Parallel(n_jobs=-1)(\n"
    "        delayed(run_single_sim)(i, simulator_obj, groups, shock_states) \n"
    "        for i in range(2000)\n"
    "    )\n"
    "    stage_counts_shock = {t: {'R32': 0, 'R16': 0, 'QF': 0, 'SF': 0, 'Finalist': 0, 'Champion': 0} for t in qualified_teams}\n"
    "    for res in sim_results_shock:\n"
    "        for t, stage in res.items():\n"
    "            if stage != 'Group':\n"
    "                stage_counts_shock[t][stage] += 1\n"
    "                \n"
    "    c = stage_counts_shock[team_name]\n"
    "    n = 2000.0\n"
    "    p_r32 = (c['R32'] + c['R16'] + c['QF'] + c['SF'] + c['Finalist'] + c['Champion']) / n\n"
    "    p_r16 = (c['R16'] + c['QF'] + c['SF'] + c['Finalist'] + c['Champion']) / n\n"
    "    p_qf = (c['QF'] + c['SF'] + c['Finalist'] + c['Champion']) / n\n"
    "    p_sf = (c['SF'] + c['Finalist'] + c['Champion']) / n\n"
    "    p_final = (c['Finalist'] + c['Champion']) / n\n"
    "    p_champion = c['Champion'] / n\n"
    "    \n"
    "    base_probs = probs_df[probs_df['team'] == team_name].iloc[0]\n"
    "    comparison = pd.DataFrame({\n"
    "        'Stage': ['Group Qualification', 'Round of 16', 'Quarterfinal', 'Semifinal', 'Final', 'Champion'],\n"
    "        'Baseline Prob': [base_probs['Round of 32'], base_probs['Round of 16'], base_probs['Quarterfinal'], base_probs['Semifinal'], base_probs['Final'], base_probs['Champion']],\n"
    "        'Mock Prob': [p_r32, p_r16, p_qf, p_sf, p_final, p_champion]\n"
    "    })\n"
    "    comparison['Difference'] = comparison['Mock Prob'] - comparison['Baseline Prob']\n"
    "    display(comparison)\n"
    "    return comparison\n"
    "\n"
    "# Run demo scenario\n"
    "run_scenario_analysis('England', -50.0, simulator, groups, initial_team_states)"
