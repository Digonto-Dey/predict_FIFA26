    "## 5.3 Monte Carlo Parallel Simulations\n\nWe run 10,000 simulations and export the aggregated stage probabilities."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build initial team states before tournament\n"
    "initial_team_states = {}\n"
    "for team in qualified_teams:\n"
    "    initial_team_states[team] = get_team_state(team, final_system.ratings, team_history)\n"
    "\n"
    "def run_single_sim(sim_id, simulator_obj, groups, initial_states):\n"
    "    np.random.seed(sim_id + 12345)\n"
    "    random.seed(sim_id + 12345)\n"
    "    states = copy.deepcopy(initial_states)\n"
    "    \n"
    "    # 1. Group Stage\n"
    "    standings, third_places = simulator_obj.simulate_group_stage(groups, states)\n"
    "    ranked_third = simulator_obj.rank_third_places(third_places, states)\n"
    "    qualifying_third = ranked_third[:8]\n"
    "    \n"
    "    winners = [standings[g][0] for g in sorted(groups.keys())]\n"
    "    runners = [standings[g][1] for g in sorted(groups.keys())]\n"
    "    \n"
    "    stages_reached = {team: 'Group' for team in qualified_teams}\n"
    "    for team in winners + runners + qualifying_third:\n"
    "        stages_reached[team] = 'R32'\n"
    "        \n"
    "    r32_pairs = [\n"
    "        (winners[0], qualifying_third[0]), (runners[0], runners[1]),\n"
    "        (winners[1], qualifying_third[1]), (runners[2], runners[3]),\n"
    "        (winners[2], qualifying_third[2]), (winners[3], qualifying_third[3]),\n"
    "        (winners[4], qualifying_third[4]), (winners[5], qualifying_third[5]),\n"
    "        (winners[6], qualifying_third[6]), (winners[7], qualifying_third[7]),\n"
    "        (winners[8], runners[9]), (winners[9], runners[8]),\n"
    "        (winners[10], runners[11]), (winners[11], runners[10]),\n"
    "        (runners[4], runners[5]), (runners[6], runners[7])\n"
    "    ]\n"
    "    r16_teams = simulator_obj.simulate_knockout_round(r32_pairs, states)\n"
    "    for team in r16_teams: stages_reached[team] = 'R16'\n"
    "        \n"
    "    r16_pairs = [(r16_teams[i], r16_teams[i+1]) for i in range(0, 16, 2)]\n"
    "    qf_teams = simulator_obj.simulate_knockout_round(r16_pairs, states)\n"
    "    for team in qf_teams: stages_reached[team] = 'QF'\n"
    "        \n"
    "    qf_pairs = [(qf_teams[i], qf_teams[i+1]) for i in range(0, 8, 2)]\n"
    "    sf_teams = simulator_obj.simulate_knockout_round(qf_pairs, states)\n"
    "    for team in sf_teams: stages_reached[team] = 'SF'\n"
    "        \n"
    "    sf_pairs = [(sf_teams[i], sf_teams[i+1]) for i in range(0, 4, 2)]\n"
    "    finalists = simulator_obj.simulate_knockout_round(sf_pairs, states)\n"
    "    for team in finalists: stages_reached[team] = 'Finalist'\n"
    "        \n"
    "    champion = simulator_obj.simulate_knockout_round([(finalists[0], finalists[1])], states)[0]\n"
    "    stages_reached[champion] = 'Champion'\n"
    "    return stages_reached\n"
    "\n"
    "simulator = TournamentSimulator(best_overall_model, final_system, initial_team_states)\n"
    "\n"
    "print(\"Starting 10,000 simulations...\")\n"
    "sim_results = Parallel(n_jobs=-1)(\n"
    "    delayed(run_single_sim)(i, simulator, groups, initial_team_states) \n"
    "    for i in range(10000)\n"
    ")\n"
    "print(\"Simulations complete!\")\n"
    "\n"
    "stage_counts = {team: {'Group': 0, 'R32': 0, 'R16': 0, 'QF': 0, 'SF': 0, 'Finalist': 0, 'Champion': 0} \n"
    "                for team in qualified_teams}\n"
    "for res in sim_results:\n"
    "    for team, stage in res.items():\n"
    "        stage_counts[team][stage] += 1\n"
    "\n"
    "prob_rows = []\n"
    "for team in qualified_teams:\n"
    "    c = stage_counts[team]\n"
    "    n = 10000.0\n"
    "    p_r32 = (c['R32'] + c['R16'] + c['QF'] + c['SF'] + c['Finalist'] + c['Champion']) / n\n"
    "    p_r16 = (c['R16'] + c['QF'] + c['SF'] + c['Finalist'] + c['Champion']) / n\n"
    "    p_qf = (c['QF'] + c['SF'] + c['Finalist'] + c['Champion']) / n\n"
    "    p_sf = (c['SF'] + c['Finalist'] + c['Champion']) / n\n"
    "    p_final = (c['Finalist'] + c['Champion']) / n\n"
    "    p_champion = c['Champion'] / n\n"
    "    prob_rows.append({\n"
    "        'team': team, 'Group Qualification': p_r32, 'Round of 32': p_r32, 'Round of 16': p_r16,\n"
    "        'Quarterfinal': p_qf, 'Semifinal': p_sf, 'Final': p_final, 'Champion': p_champion\n"
    "    })\n"
    "\n"
    "probs_df = pd.DataFrame(prob_rows)\n"
    "probs_df = probs_df.sort_values('Champion', ascending=False).reset_index(drop=True)\n"
    "\n"
    "probs_df.to_csv(os.path.join('outputs', 'qualification_probabilities.csv'), index=False)\n"
    "probs_df[['team', 'Champion']].to_csv(os.path.join('outputs', 'champion_probabilities.csv'), index=False)\n"
    "pd.DataFrame.from_dict(stage_counts, orient='index').to_csv(os.path.join('outputs', 'simulation_results.csv'))\n"
    "\n"
    "print(\"Saved outputs.\")\n"
    "display(probs_df.head(15))"
   ]
