   "source": "import shap\nfrom sklearn.inspection import permutation_importance\n\nsingle_models = comparison_df[~comparison_df['Model'].str.contains('Ensemble')]\nbest_single = single_models.iloc[0]\nbest_model_name = best_single['Model']\nbest_cal_type = best_single['Calibration']\n\nprint(f'Best single model: {best_model_name} ({best_cal_type})')\nbase_model = models[best_model_name]['base']\n\nif hasattr(base_model, 'feature_importances_'):\n    feat_imp = pd.DataFrame({\n        'Feature': features,\n        'Importance': base_model.feature_importances_\n    }).sort_values('Importance', ascending=False)\n    feat_imp.to_csv(os.path.join('outputs', 'feature_importance.csv'), index=False)\n    \n    plt.figure(figsize=(12, 6))\n    sns.barplot(data=feat_imp.head(15), x='Importance', y='Feature', palette='viridis')\n    plt.title(f'Top 15 Feature Importances ({best_model_name})', fontsize=14, fontweight='bold')\n    plt.tight_layout()\n    plt.savefig(os.path.join(OUTPUT_FIG_DIR, 'feature_importance.png'), dpi=150)\n    plt.show()\n\nprint('Calculating Permutation Importance...')\nperm_imp = permutation_importance(base_model, X_test_scaled_df, y_test, n_repeats=5, random_state=42, n_jobs=-1)\nperm_df = pd.DataFrame({\n    'Feature': features,\n    'Importance_Mean': perm_imp.importances_mean,\n    'Importance_Std': perm_imp.importances_std\n}).sort_values('Importance_Mean', ascending=False)\nperm_df.to_csv(os.path.join('outputs', 'permutation_importance.csv'), index=False)\n\nprint('Running SHAP Explainer...')\nif best_model_name in ['XGBoost', 'LightGBM', 'CatBoost', 'Random Forest']:\n    explainer = shap.TreeExplainer(base_model)\n    shap_sample = X_test_scaled_df.sample(min(200, len(X_test_scaled_df)), random_state=42)\n    shap_values = explainer.shap_values(shap_sample)\n    \n    plt.figure(figsize=(12, 8))\n    if isinstance(shap_values, list):\n        shap.summary_plot(shap_values[2], shap_sample, show=False)\n    else: \n        if len(shap_values.shape) == 3:\n            shap.summary_plot(shap_values[:, :, 2], shap_sample, show=False)\n        else:\n            shap.summary_plot(shap_values, shap_sample, show=False)\n            \n    plt.title(f'SHAP Summary Plot - Home Win Class ({best_model_name})', fontsize=14, fontweight='bold')\n    plt.tight_layout()\n    plt.savefig(os.path.join(OUTPUT_FIG_DIR, 'shap_summary.png'), dpi=150)\n    plt.show()\n\nbest_overall_model = {\n    'model_name': best_model_name,\n    'calibration_type': best_cal_type,\n    'scaler': scaler,\n    'features': features,\n    'label_encoder': le\n}\n\nif best_cal_type == 'Isotonic':\n    best_overall_model['model'] = models[best_model_name]['cal_isotonic']\nelif best_cal_type == 'Platt/Temp':\n    if best_model_name == 'Neural Network':\n        best_overall_model['model'] = models[best_model_name]['base']\n        best_overall_model['temp_scaler'] = models[best_model_name]['temp_scaler']\n    else:\n        best_overall_model['model'] = models[best_model_name]['cal_platt']\nelse:\n    best_overall_model['model'] = models[best_model_name]['base']\n\nwith open(os.path.join('outputs', 'best_model.pkl'), 'wb') as f:\n    pickle.dump(best_overall_model, f)\nprint('Saved outputs/best_model.pkl')"
