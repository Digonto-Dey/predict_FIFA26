    "\n",
    "# Remove invalid rows\n",
    "invalid_mask = (\n",
    "    results['date'].isna() |\n",
    "    results['home_team'].isna() |\n",
    "    results['away_team'].isna() |\n",
    "    results['home_score'].isna() |\n",
    "    results['away_score'].isna() |\n",
