   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5.2 World Cup Simulator Engine\n\nWe declare the TournamentSimulator class which runs group match-play and knockout ties, resolving draws with relative 90-minute win probabilities."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from joblib import Parallel, delayed\nimport copy\n\nwith open(os.path.join('outputs', 'best_model.pkl'), 'rb') as f:\n    best_model_data = pickle.load(f)\n\nml_model = best_model_data['model']\nscaler = best_model_data['scaler']\nfeatures_list = best_model_data['features']\nle_encoder = best_model_data['label_encoder']\n\ntry:\n    wc_tier_encoded = le_encoder.transform(['world_cup'])[0]\nexcept:\n    wc_tier_encoded = 0\n\ndef get_team_state(team, ratings, team_history):\n    rating = ratings.get(team, 1500)\n    hist = team_history.get(team, [])\n    if len(hist) == 0:\n        return {\n            'rating': rating, 'form_pts_l5': 0, 'goals_scored_l5': 0.0, 'goals_conceded_l5': 0.0,\n            'win_pct_l10': 0.0, 'draw_pct_l10': 0.0, 'loss_pct_l10': 0.0,\n            'avg_opp_rating_l5': rating, 'avg_opp_rating_l10': rating, 'adj_gd_l5': 0.0, 'uncertainty': 0\n        }\n    l5 = hist[-5:]\n    form_pts = sum([m['points'] for m in l5])\n    gs_l5 = np.mean([m['goals_scored'] for m in l5])\n    gc_l5 = np.mean([m['goals_conceded'] for m in l5])\n    opp_l5 = np.mean([m['opponent_rating'] for m in l5])\n    adj_gd_l5 = np.mean([m['adj_gd'] for m in l5])\n    \n    l10 = hist[-10:]\n    n_m = len(l10)\n    win_l10 = sum([1 for m in l10 if m['points'] == 3]) / n_m\n    draw_l10 = sum([1 for m in l10 if m['points'] == 1]) / n_m\n    loss_l10 = sum([1 for m in l10 if m['points'] == 0]) / n_m\n    opp_l10 = np.mean([m['opponent_rating'] for m in l10])\n    \n    uncertainty = final_system.rd.get(team, 0) if hasattr(final_system, 'rd') else 0\n    return {\n        'rating': rating, 'form_pts_l5': form_pts, 'goals_scored_l5': gs_l5, 'goals_conceded_l5': gc_l5,\n        'win_pct_l10': win_l10, 'draw_pct_l10': draw_l10, 'loss_pct_l10': loss_l10,\n        'avg_opp_rating_l5': opp_l5, 'avg_opp_rating_l10': opp_l10, 'adj_gd_l5': adj_gd_l5, 'uncertainty': uncertainty\n    }\n\nclass TournamentSimulator:\n    def __init__(self, model_data, final_system, initial_states):\n        self.model = model_data['model']\n        self.scaler = model_data['scaler']\n        self.features = model_data['features']\n        self.le = model_data['label_encoder']\n        self.final_system = final_system\n        self.initial_states = initial_states\n        try:\n            self.wc_tier = self.le.transform(['world_cup'])[0]\n        except:\n            self.wc_tier = 0\n            \n    def get_elo_probs(self, rating_h, rating_a, is_neutral):\n        ha = self.final_system.home_advantage if (self.final_system.use_home_advantage and not is_neutral) else 0\n        pi_h = 10.0 ** ((rating_h + ha) / 400.0)\n        pi_a = 10.0 ** (rating_a / 400.0)\n        nu = self.final_system.draw_param\n        sqrt_term = nu * np.sqrt(pi_h * pi_a)\n        denom = pi_h + pi_a + sqrt_term\n        return pi_h / denom, sqrt_term / denom, pi_a / denom\n\n    def predict_match_probs(self, team_h, team_a, states, is_neutral=True):\n        sh = states[team_h]\n        sa = states[team_a]\n        \n        elo_h, elo_d, elo_a = self.get_elo_probs(sh['rating'], sa['rating'], is_neutral)\n        ha = self.final_system.home_advantage if (not is_neutral) else 0\n        uncertainty = (sh['uncertainty'] + sa['uncertainty']) / 2\n        \n        raw_features = {\n            'home_rating_pre': sh['rating'], 'away_rating_pre': sa['rating'], 'rating_difference': sh['rating'] - sa['rating'],\n            'expected_home_win': elo_h, 'expected_draw': elo_d, 'expected_away_win': elo_a,\n            'home_advantage': ha, 'tournament_weight': 1.0, 'rating_uncertainty': uncertainty, 'is_neutral': 1.0 if is_neutral else 0.0,\n            'home_form_pts_l5': sh['form_pts_l5'], 'away_form_pts_l5': sa['form_pts_l5'], 'form_difference': sh['form_pts_l5'] - sa['form_pts_l5'],\n            'home_goals_scored_l5': sh['goals_scored_l5'], 'home_goals_conceded_l5': sh['goals_conceded_l5'], 'home_goal_diff_l5': sh['goals_scored_l5'] - sh['goals_conceded_l5'],\n            'away_goals_scored_l5': sa['goals_scored_l5'], 'away_goals_conceded_l5': sa['goals_conceded_l5'], 'away_goal_diff_l5': sa['goals_scored_l5'] - sa['goals_conceded_l5'],\n            'home_win_pct_l10': sh['win_pct_l10'], 'home_draw_pct_l10': sh['draw_pct_l10'], 'home_loss_pct_l10': sh['loss_pct_l10'],\n            'away_win_pct_l10': sa['win_pct_l10'], 'away_draw_pct_l10': sa['draw_pct_l10'], 'away_loss_pct_l10': sa['loss_pct_l10'],\n            'home_avg_opp_rating_l5': sh['avg_opp_rating_l5'], 'away_avg_opp_rating_l5': sa['avg_opp_rating_l5'],\n            'home_avg_opp_rating_l10': sh['avg_opp_rating_l10'], 'away_avg_opp_rating_l10': sa['avg_opp_rating_l10'],\n            'home_adj_gd_l5': sh['adj_gd_l5'], 'away_adj_gd_l5': sa['adj_gd_l5'], 'tournament_tier_encoded': self.wc_tier\n        }\n        X_df = pd.DataFrame([raw_features])[self.features]\n        X_scaled = self.scaler.transform(X_df)\n        \n        if 'temp_scaler' in best_model_data:\n            base_probs = self.model.predict_proba(X_scaled)\n            base_probs = np.clip(base_probs, 1e-15, 1 - 1e-15)\n            logits = np.log(base_probs)\n            probs = best_model_data['temp_scaler'].transform(logits)[0]\n        else:\n            probs = self.model.predict_proba(X_scaled)[0]\n            \n        probs = probs / np.sum(probs)\n        return probs[2], probs[1], probs[0]\n\n    def simulate_goals(self, p_h, p_d, p_a, team_h, team_a, states, outcome):\n        rating_diff = states[team_h]['rating'] - states[team_a]['rating']\n        lambda_h = max(0.5, 1.3 + rating_diff / 400.0)\n        lambda_a = max(0.5, 1.3 - rating_diff / 400.0)\n        for _ in range(100):\n            gh = np.random.poisson(lambda_h)\n            ga = np.random.poisson(lambda_a)\n            if outcome == 'H' and gh > ga:\n                return gh, ga\n            elif outcome == 'D' and gh == ga:\n                return gh, ga\n            elif outcome == 'A' and gh < ga:\n                return gh, ga\n        if outcome == 'H': return 2, 1 if np.random.random() < 0.6 else 1, 0\n        elif outcome == 'D': return 1, 1 if np.random.random() < 0.7 else 0, 0\n        else: return 1, 2 if np.random.random() < 0.6 else 0, 1\n\n    def update_team_states(self, team_h, team_a, gh, ga, states):\n        sh = states[team_h]\n        sa = states[team_a]\n        exp_h = 1.0 / (1.0 + 10.0 ** ((sa['rating'] - sh['rating']) / 400.0))\n        act_h = 1.0 if gh > ga else (0.5 if gh == ga else 0.0)\n        k = 40.0\n        sh['rating'] += k * (act_h - exp_h)\n        sa['rating'] += k * ((1.0 - act_h) - (1.0 - exp_h))\n        \n        h_pts = 3 if gh > ga else (1 if gh == ga else 0)\n        a_pts = 3 if gh < ga else (1 if gh == ga else 0)\n        h_adj_gd = (gh - ga) + (sa['rating'] - sh['rating']) / 100\n        a_adj_gd = (ga - gh) + (sh['rating'] - sa['rating']) / 100\n        \n        if 'history' not in sh: sh['history'] = []\n        if 'history' not in sa: sa['history'] = []\n        sh['history'].append({'points': h_pts, 'goals_scored': gh, 'goals_conceded': ga, 'opponent_rating': sa['rating'], 'adj_gd': h_adj_gd})\n        sa['history'].append({'points': a_pts, 'goals_scored': ga, 'goals_conceded': gh, 'opponent_rating': sh['rating'], 'adj_gd': a_adj_gd})\n        sh['history'] = sh['history'][-10:]\n        sa['history'] = sa['history'][-10:]\n        \n        for s in [sh, sa]:\n            hist = s['history']\n            l5 = hist[-5:]\n            s['form_pts_l5'] = sum([m['points'] for m in l5])\n            s['goals_scored_l5'] = np.mean([m['goals_scored'] for m in l5])\n            s['goals_conceded_l5'] = np.mean([m['goals_conceded'] for m in l5])\n            s['avg_opp_rating_l5'] = np.mean([m['opponent_rating'] for m in l5])\n            s['adj_gd_l5'] = np.mean([m['adj_gd'] for m in l5])\n            n_m = len(hist)\n            s['win_pct_l10'] = sum([1 for m in hist if m['points'] == 3]) / n_m\n            s['draw_pct_l10'] = sum([1 for m in hist if m['points'] == 1]) / n_m\n            s['loss_pct_l10'] = sum([1 for m in hist if m['points'] == 0]) / n_m\n            s['avg_opp_rating_l10'] = np.mean([m['opponent_rating'] for m in hist])\n\n    def simulate_group_stage(self, groups, states):\n        standings = {}\n        third_places = {}\n        for g_letter, g_teams in groups.items():\n            g_stats = {team: {'points': 0, 'gd': 0, 'gs': 0} for team in g_teams}\n            for i in range(4):\n                for j in range(i+1, 4):\n                    team_i = g_teams[i]\n                    team_j = g_teams[j]\n                    p_win_i, p_draw, p_win_j = self.predict_match_probs(team_i, team_j, states, is_neutral=True)\n                    rand = np.random.random()\n                    if rand < p_win_i:\n                        outcome = 'H'\n                        g_stats[team_i]['points'] += 3\n                    elif rand < p_win_i + p_draw:\n                        outcome = 'D'\n                        g_stats[team_i]['points'] += 1\n                        g_stats[team_j]['points'] += 1\n                    else:\n                        outcome = 'A'\n                        g_stats[team_j]['points'] += 3\n                    gh, ga = self.simulate_goals(p_win_i, p_draw, p_win_j, team_i, team_j, states, outcome)\n                    g_stats[team_i]['gd'] += (gh - ga)\n                    g_stats[team_j]['gd'] += (ga - gh)\n                    g_stats[team_i]['gs'] += gh\n                    g_stats[team_j]['gs'] += ga\n                    self.update_team_states(team_i, team_j, gh, ga, states)\n            sorted_teams = sorted(g_teams, key=lambda t: (\n                g_stats[t]['points'], g_stats[t]['gd'], g_stats[t]['gs'], states[t]['rating']\n            ), reverse=True)\n            standings[g_letter] = sorted_teams\n            third_places[g_letter] = {\n                'team': sorted_teams[2], 'points': g_stats[sorted_teams[2]]['points'],\n                'gd': g_stats[sorted_teams[2]]['gd'], 'gs': g_stats[sorted_teams[2]]['gs']\n            }\n        return standings, third_places\n\n    def rank_third_places(self, third_places, states):\n        list_thirds = list(third_places.values())\n        sorted_thirds = sorted(list_thirds, key=lambda x: (\n            x['points'], x['gd'], x['gs'], states[x['team']]['rating']\n        ), reverse=True)\n        return [x['team'] for x in sorted_thirds]\n\n    def simulate_knockout_round(self, pairs, states):\n        winners = []\n        for team_a, team_b in pairs:\n            p_win_a, p_draw, p_win_b = self.predict_match_probs(team_a, team_b, states, is_neutral=True)\n            rand = np.random.random()\n            if rand < p_win_a:\n                winner = team_a\n                gh, ga = self.simulate_goals(p_win_a, p_draw, p_win_b, team_a, team_b, states, 'H')\n            elif rand < p_win_a + p_draw:\n                prob_a_advance = p_win_a / (p_win_a + p_win_b) if (p_win_a + p_win_b) > 0 else 0.5\n                if np.random.random() < prob_a_advance:\n                    winner = team_a\n                    gh, ga = self.simulate_goals(p_win_a, p_draw, p_win_b, team_a, team_b, states, 'H')\n                else:\n                    winner = team_b\n                    gh, ga = self.simulate_goals(p_win_a, p_draw, p_win_b, team_a, team_b, states, 'A')\n            else:\n                winner = team_b\n                gh, ga = self.simulate_goals(p_win_a, p_draw, p_win_b, team_a, team_b, states, 'A')\n            self.update_team_states(team_a, team_b, gh, ga, states)\n            winners.append(winner)\n        return winners"
   ]
