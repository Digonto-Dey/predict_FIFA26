   "cell_type": "markdown",
   "metadata": {},
   "source": "# ═══════════════════════════════════════════════\n# SETUP NEW REQUIREMENTS\n# ═══════════════════════════════════════════════"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "# Install any newly added libraries in requirements.txt\n!pip install -r requirements.txt"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "# ═══════════════════════════════════════════════\n# PHASE 4: MACHINE LEARNING MATCH PREDICTION ENGINE\n# ═══════════════════════════════════════════════\n\n## 4.1 Feature Engineering Pipeline\n\nWe build an $O(N)$ chronological history tracker for each team to compute rolling form features, goals averages, and opponent-adjusted strength metrics without lookahead bias."
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "import os\nimport pandas as pd\nimport numpy as np\nfrom collections import defaultdict\n\nratings_df = pd.read_csv(os.path.join('ratings', 'match_rating_features.csv'), parse_dates=['date'])\nratings_df = ratings_df.sort_values('date').reset_index(drop=True)\n\nteam_history = defaultdict(list)\n\nhome_form_pts_l5 = []\naway_form_pts_l5 = []\nhome_goals_scored_l5 = []\nhome_goals_conceded_l5 = []\naway_goals_scored_l5 = []\naway_goals_conceded_l5 = []\nhome_win_pct_l10 = []\nhome_draw_pct_l10 = []\nhome_loss_pct_l10 = []\naway_win_pct_l10 = []\naway_draw_pct_l10 = []\naway_loss_pct_l10 = []\nhome_avg_opp_rating_l5 = []\naway_avg_opp_rating_l5 = []\nhome_avg_opp_rating_l10 = []\naway_avg_opp_rating_l10 = []\nhome_adj_gd_l5 = []\naway_adj_gd_l5 = []\n\nfor idx, row in ratings_df.iterrows():\n    h_team = row['home_team']\n    a_team = row['away_team']\n    h_rating = row['home_rating_pre']\n    a_rating = row['away_rating_pre']\n    \n    h_hist = team_history[h_team]\n    if len(h_hist) == 0:\n        home_form_pts_l5.append(0)\n        home_goals_scored_l5.append(0.0)\n        home_goals_conceded_l5.append(0.0)\n        home_win_pct_l10.append(0.0)\n        home_draw_pct_l10.append(0.0)\n        home_loss_pct_l10.append(0.0)\n        home_avg_opp_rating_l5.append(h_rating)\n        home_avg_opp_rating_l10.append(h_rating)\n        home_adj_gd_l5.append(0.0)\n    else:\n        l5 = h_hist[-5:]\n        home_form_pts_l5.append(sum([m['points'] for m in l5]))\n        home_goals_scored_l5.append(np.mean([m['goals_scored'] for m in l5]))\n        home_goals_conceded_l5.append(np.mean([m['goals_conceded'] for m in l5]))\n        home_avg_opp_rating_l5.append(np.mean([m['opponent_rating'] for m in l5]))\n        home_adj_gd_l5.append(np.mean([m['adj_gd'] for m in l5]))\n        \n        l10 = h_hist[-10:]\n        n_m = len(l10)\n        home_win_pct_l10.append(sum([1 for m in l10 if m['points'] == 3]) / n_m)\n        home_draw_pct_l10.append(sum([1 for m in l10 if m['points'] == 1]) / n_m)\n        home_loss_pct_l10.append(sum([1 for m in l10 if m['points'] == 0]) / n_m)\n        home_avg_opp_rating_l10.append(np.mean([m['opponent_rating'] for m in l10]))\n        \n    a_hist = team_history[a_team]\n    if len(a_hist) == 0:\n        away_form_pts_l5.append(0)\n        away_goals_scored_l5.append(0.0)\n        away_goals_conceded_l5.append(0.0)\n        away_win_pct_l10.append(0.0)\n        away_draw_pct_l10.append(0.0)\n        away_loss_pct_l10.append(0.0)\n        away_avg_opp_rating_l5.append(a_rating)\n        away_avg_opp_rating_l10.append(a_rating)\n        away_adj_gd_l5.append(0.0)\n    else:\n        l5 = a_hist[-5:]\n        away_form_pts_l5.append(sum([m['points'] for m in l5]))\n        away_goals_scored_l5.append(np.mean([m['goals_scored'] for m in l5]))\n        away_goals_conceded_l5.append(np.mean([m['goals_conceded'] for m in l5]))\n        away_avg_opp_rating_l5.append(np.mean([m['opponent_rating'] for m in l5]))\n        away_adj_gd_l5.append(np.mean([m['adj_gd'] for m in l5]))\n        \n        l10 = a_hist[-10:]\n        n_m = len(l10)\n        away_win_pct_l10.append(sum([1 for m in l10 if m['points'] == 3]) / n_m)\n        away_draw_pct_l10.append(sum([1 for m in l10 if m['points'] == 1]) / n_m)\n        away_loss_pct_l10.append(sum([1 for m in l10 if m['points'] == 0]) / n_m)\n        away_avg_opp_rating_l10.append(np.mean([m['opponent_rating'] for m in l10]))\n        \n    h_score = row['home_score']\n    a_score = row['away_score']\n    if h_score > a_score:\n        h_pts, a_pts = 3, 0\n    elif h_score == a_score:\n        h_pts, a_pts = 1, 1\n    else:\n        h_pts, a_pts = 0, 3\n        \n    h_adj_gd = (h_score - a_score) + (a_rating - h_rating) / 100\n    a_adj_gd = (a_score - h_score) + (h_rating - a_rating) / 100\n    \n    team_history[h_team].append({\n        'date': row['date'], 'goals_scored': h_score, 'goals_conceded': a_score,\n        'points': h_pts, 'opponent_rating': a_rating, 'adj_gd': h_adj_gd\n    })\n    team_history[a_team].append({\n        'date': row['date'], 'goals_scored': a_score, 'goals_conceded': h_score,\n        'points': a_pts, 'opponent_rating': h_rating, 'adj_gd': a_adj_gd\n    })\n\nfeatures_df = ratings_df.copy()\nfeatures_df['home_form_pts_l5'] = home_form_pts_l5\nfeatures_df['away_form_pts_l5'] = away_form_pts_l5\nfeatures_df['form_difference'] = features_df['home_form_pts_l5'] - features_df['away_form_pts_l5']\nfeatures_df['home_goals_scored_l5'] = home_goals_scored_l5\nfeatures_df['home_goals_conceded_l5'] = home_goals_conceded_l5\nfeatures_df['home_goal_diff_l5'] = features_df['home_goals_scored_l5'] - features_df['home_goals_conceded_l5']\nfeatures_df['away_goals_scored_l5'] = away_goals_scored_l5\nfeatures_df['away_goals_conceded_l5'] = away_goals_conceded_l5\nfeatures_df['away_goal_diff_l5'] = features_df['away_goals_scored_l5'] - features_df['away_goals_conceded_l5']\n\nfeatures_df['home_win_pct_l10'] = home_win_pct_l10\nfeatures_df['home_draw_pct_l10'] = home_draw_pct_l10\nfeatures_df['home_loss_pct_l10'] = home_loss_pct_l10\nfeatures_df['away_win_pct_l10'] = away_win_pct_l10\nfeatures_df['away_draw_pct_l10'] = away_draw_pct_l10\nfeatures_df['away_loss_pct_l10'] = away_loss_pct_l10\n\nfeatures_df['home_avg_opp_rating_l5'] = home_avg_opp_rating_l5\nfeatures_df['away_avg_opp_rating_l5'] = away_avg_opp_rating_l5\nfeatures_df['home_avg_opp_rating_l10'] = home_avg_opp_rating_l10\nfeatures_df['away_avg_opp_rating_l10'] = away_avg_opp_rating_l10\nfeatures_df['home_adj_gd_l5'] = home_adj_gd_l5\nfeatures_df['away_adj_gd_l5'] = away_adj_gd_l5\n\nfeatures_df.to_csv(os.path.join(DATA_DIR, 'match_prediction_dataset.csv'), index=False)\nprint(f'Dataset generated. Shape: {features_df.shape}')"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## 4.2 Chronological Validation Split & Scaling\n\nWe split the matches chronologically into Train (before 2021-01-01), Validation (2021-01-01 to 2024-01-01), and Test (2024-01-01 to present) sets, and apply standard scaling."
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "from sklearn.preprocessing import StandardScaler, LabelEncoder\nfrom sklearn.linear_model import LogisticRegression\nfrom sklearn.ensemble import RandomForestClassifier\nfrom xgboost import XGBClassifier\nfrom lightgbm import LGBMClassifier\nfrom catboost import CatBoostClassifier\nfrom sklearn.neural_network import MLPClassifier\nimport optuna\nimport pickle\n\ndf_ml = pd.read_csv(os.path.join(DATA_DIR, 'match_prediction_dataset.csv'), parse_dates=['date'])\ndf_ml = df_ml.sort_values('date').reset_index(drop=True)\n\nfeatures = [\n    'home_rating_pre', 'away_rating_pre', 'rating_difference',\n    'expected_home_win', 'expected_draw', 'expected_away_win',\n    'home_advantage', 'tournament_weight', 'rating_uncertainty',\n    'is_neutral', 'home_form_pts_l5', 'away_form_pts_l5', 'form_difference',\n    'home_goals_scored_l5', 'home_goals_conceded_l5', 'home_goal_diff_l5',\n    'away_goals_scored_l5', 'away_goals_conceded_l5', 'away_goal_diff_l5',\n    'home_win_pct_l10', 'home_draw_pct_l10', 'home_loss_pct_l10',\n    'away_win_pct_l10', 'away_draw_pct_l10', 'away_loss_pct_l10',\n    'home_avg_opp_rating_l5', 'away_avg_opp_rating_l5',\n    'home_avg_opp_rating_l10', 'away_avg_opp_rating_l10',\n    'home_adj_gd_l5', 'away_adj_gd_l5'\n]\n\nle = LabelEncoder()\ndf_ml['tournament_tier_encoded'] = le.fit_transform(df_ml['tournament_tier'])\nfeatures.append('tournament_tier_encoded')\n\nX = df_ml[features]\ny = df_ml['actual_result']\n\nTRAIN_END = pd.Timestamp('2021-01-01')\nVAL_END = pd.Timestamp('2024-01-01')\n\ntrain_idx = df_ml['date'] < TRAIN_END\nval_idx = (df_ml['date'] >= TRAIN_END) & (df_ml['date'] < VAL_END)\ntest_idx = df_ml['date'] >= VAL_END\n\nX_train, y_train = X[train_idx], y[train_idx]\nX_val, y_val = X[val_idx], y[val_idx]\nX_test, y_test = X[test_idx], y[test_idx]\n\nscaler = StandardScaler()\nX_train_scaled = scaler.fit_transform(X_train)\nX_val_scaled = scaler.transform(X_val)\nX_test_scaled = scaler.transform(X_test)\n\nX_train_scaled_df = pd.DataFrame(X_train_scaled, columns=features)\nX_val_scaled_df = pd.DataFrame(X_val_scaled, columns=features)\nX_test_scaled_df = pd.DataFrame(X_test_scaled, columns=features)\n\nprint(f'Train set: {X_train.shape[0]} matches')\nprint(f'Val set  : {X_val.shape[0]} matches')\nprint(f'Test set : {X_test.shape[0]} matches')"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## 4.3 Hyperparameter Tuning with Optuna\n\nWe optimize parameters for Random Forest, XGBoost, LightGBM, and CatBoost using Optuna."
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "optuna.logging.set_verbosity(optuna.logging.WARNING)\n\ndef objective_rf(trial):\n    params = {\n        'n_estimators': trial.suggest_int('n_estimators', 50, 150),\n        'max_depth': trial.suggest_int('max_depth', 5, 12),\n        'min_samples_split': trial.suggest_int('min_samples_split', 2, 15),\n        'min_samples_leaf': trial.suggest_int('min_samples_leaf', 1, 8),\n        'random_state': 42,\n        'n_jobs': -1\n    }\n    model = RandomForestClassifier(**params)\n    model.fit(X_train_scaled_df, y_train)\n    preds = model.predict_proba(X_val_scaled_df)\n    return log_loss(y_val, preds)\n\nstudy_rf = optuna.create_study(direction='minimize')\nstudy_rf.optimize(objective_rf, n_trials=10)\nrf_best_params = study_rf.best_params\nprint('RF Best Params:', rf_best_params)\n\ndef objective_xgb(trial):\n    params = {\n        'n_estimators': trial.suggest_int('n_estimators', 50, 150),\n        'max_depth': trial.suggest_int('max_depth', 3, 7),\n        'learning_rate': trial.suggest_float('learning_rate', 0.01, 0.15, log=True),\n        'subsample': trial.suggest_float('subsample', 0.6, 0.95),\n        'colsample_bytree': trial.suggest_float('colsample_bytree', 0.6, 0.95),\n        'random_state': 42,\n        'n_jobs': -1,\n        'eval_metric': 'mlogloss'\n    }\n    model = XGBClassifier(**params)\n    model.fit(X_train_scaled_df, y_train)\n    preds = model.predict_proba(X_val_scaled_df)\n    return log_loss(y_val, preds)\n\nstudy_xgb = optuna.create_study(direction='minimize')\nstudy_xgb.optimize(objective_xgb, n_trials=10)\nxgb_best_params = study_xgb.best_params\nprint('XGB Best Params:', xgb_best_params)\n\ndef objective_lgb(trial):\n    params = {\n        'n_estimators': trial.suggest_int('n_estimators', 50, 150),\n        'max_depth': trial.suggest_int('max_depth', 3, 7),\n        'learning_rate': trial.suggest_float('learning_rate', 0.01, 0.15, log=True),\n        'num_leaves': trial.suggest_int('num_leaves', 8, 48),\n        'subsample': trial.suggest_float('subsample', 0.6, 0.95),\n        'colsample_bytree': trial.suggest_float('colsample_bytree', 0.6, 0.95),\n        'random_state': 42,\n        'n_jobs': -1,\n        'verbose': -1\n    }\n    model = LGBMClassifier(**params)\n    model.fit(X_train_scaled_df, y_train)\n    preds = model.predict_proba(X_val_scaled_df)\n    return log_loss(y_val, preds)\n\nstudy_lgb = optuna.create_study(direction='minimize')\nstudy_lgb.optimize(objective_lgb, n_trials=10)\nlgb_best_params = study_lgb.best_params\nprint('LGB Best Params:', lgb_best_params)\n\ndef objective_cat(trial):\n    params = {\n        'iterations': trial.suggest_int('iterations', 50, 150),\n        'depth': trial.suggest_int('depth', 3, 7),\n        'learning_rate': trial.suggest_float('learning_rate', 0.01, 0.15, log=True),\n        'random_seed': 42,\n        'verbose': 0,\n        'thread_count': -1,\n        'allow_writing_files': False\n    }\n    model = CatBoostClassifier(**params)\n    model.fit(X_train_scaled_df, y_train)\n    preds = model.predict_proba(X_val_scaled_df)\n    return log_loss(y_val, preds)\n\nstudy_cat = optuna.create_study(direction='minimize')\nstudy_cat.optimize(objective_cat, n_trials=10)\ncat_best_params = study_cat.best_params\nprint('CatBoost Best Params:', cat_best_params)"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## 4.4 Model Fitting & Calibration\n\nWe fit the models and calibrate them using Platt/Isotonic scaling or custom Temperature Scaling."
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "from sklearn.calibration import CalibratedClassifierCV\nfrom scipy.optimize import minimize\nfrom sklearn.metrics import precision_recall_fscore_support\n\nclass TemperatureScaler:\n    def __init__(self):\n        self.temp = 1.0\n        \n    def fit(self, logits, y_val):\n        def loss_func(t):\n            scaled_logits = logits / t\n            exp_logits = np.exp(scaled_logits - np.max(scaled_logits, axis=1, keepdims=True))\n            probs = exp_logits / np.sum(exp_logits, axis=1, keepdims=True)\n            probs = np.clip(probs, 1e-15, 1 - 1e-15)\n            y_onehot = np.zeros_like(probs)\n            for i, val in enumerate(y_val):\n                y_onehot[i, val] = 1\n            return -np.mean(np.sum(y_onehot * np.log(probs), axis=1))\n            \n        res = minimize(loss_func, x0=[1.0], bounds=[(0.1, 10.0)], method='L-BFGS-B')\n        self.temp = res.x[0]\n        return self\n        \n    def transform(self, logits):\n        scaled_logits = logits / self.temp\n        exp_logits = np.exp(scaled_logits - np.max(scaled_logits, axis=1, keepdims=True))\n        return exp_logits / np.sum(exp_logits, axis=1, keepdims=True)\n\n# 1. Base Classifiers\nlr_model = LogisticRegression(multi_class='multinomial', max_iter=1000, random_state=42)\nrf_model = RandomForestClassifier(**rf_best_params)\nxgb_model = XGBClassifier(**xgb_best_params)\nlgb_model = LGBMClassifier(**lgb_best_params)\ncat_model = CatBoostClassifier(**cat_best_params)\nmlp_model = MLPClassifier(hidden_layer_sizes=(64, 32), max_iter=500, early_stopping=True, random_state=42)\n\nmodels = {}\n\n# Fit and Calibrate\nfor name, base_clf in [\n    ('Logistic Regression', lr_model),\n    ('Random Forest', rf_model),\n    ('XGBoost', xgb_model),\n    ('LightGBM', lgb_model),\n    ('CatBoost', cat_model)\n]:\n    print(f'Training and calibrating {name}...')\n    base_clf.fit(X_train_scaled_df, y_train)\n    \n    cal_iso = CalibratedClassifierCV(base_clf, method='isotonic', cv='prefit')\n    cal_iso.fit(X_val_scaled_df, y_val)\n    \n    cal_plat = CalibratedClassifierCV(base_clf, method='sigmoid', cv='prefit')\n    cal_plat.fit(X_val_scaled_df, y_val)\n    \n    models[name] = {\n        'base': base_clf,\n        'cal_isotonic': cal_iso,\n        'cal_platt': cal_plat\n    }\n\n# Neural Network with Temperature Scaling\nprint('Training Neural Network (MLP)...')\nmlp_model.fit(X_train_scaled_df, y_train)\nval_probs = mlp_model.predict_proba(X_val_scaled_df)\nval_probs = np.clip(val_probs, 1e-15, 1 - 1e-15)\nval_logits = np.log(val_probs)\n\ntemp_scaler = TemperatureScaler()\ntemp_scaler.fit(val_logits, y_val.values)\nprint(f'MLP Optimal Temperature T = {temp_scaler.temp:.4f}')\n\nmodels['Neural Network'] = {\n    'base': mlp_model,\n    'temp_scaler': temp_scaler\n}"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## 4.5 Model Evaluation & Ensemble Comparison\n\nWe calculate metrics and create a Stacking Ensemble of the top 3 calibrated models."
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "def compute_rps(y_true, probs):\n    y_true_onehot = np.zeros((len(y_true), 3))\n    for i, val in enumerate(y_true):\n        y_true_onehot[i, val] = 1.0\n    cum_pred = np.cumsum(probs, axis=1)\n    cum_actual = np.cumsum(y_true_onehot, axis=1)\n    return np.mean(np.sum((cum_pred - cum_actual) ** 2, axis=1) / 2)\n\ndef compute_ece(y_true, probs, n_bins=10):\n    confidences = np.max(probs, axis=1)\n    predictions = np.argmax(probs, axis=1)\n    accuracies = (predictions == y_true)\n    ece = 0.0\n    bins = np.linspace(0, 1, n_bins + 1)\n    for i in range(n_bins):\n        in_bin = (confidences >= bins[i]) & (confidences < bins[i+1])\n        prop_in_bin = np.mean(in_bin)\n        if prop_in_bin > 0:\n            accuracy_in_bin = np.mean(accuracies[in_bin])\n            avg_confidence_in_bin = np.mean(confidences[in_bin])\n            ece += prop_in_bin * np.abs(avg_confidence_in_bin - accuracy_in_bin)\n    return ece\n\neval_rows = []\n\nfor name, model_dict in models.items():\n    for mode in ['Uncalibrated', 'Isotonic', 'Platt/Temp']:\n        if name == 'Neural Network':\n            if mode == 'Isotonic':\n                continue\n            elif mode == 'Uncalibrated':\n                val_probs = model_dict['base'].predict_proba(X_val_scaled_df)\n                test_probs = model_dict['base'].predict_proba(X_test_scaled_df)\n            else:\n                val_probs_base = model_dict['base'].predict_proba(X_val_scaled_df)\n                val_probs_base = np.clip(val_probs_base, 1e-15, 1 - 1e-15)\n                val_logits = np.log(val_probs_base)\n                val_probs = model_dict['temp_scaler'].transform(val_logits)\n                \n                test_probs_base = model_dict['base'].predict_proba(X_test_scaled_df)\n                test_probs_base = np.clip(test_probs_base, 1e-15, 1 - 1e-15)\n                test_logits = np.log(test_probs_base)\n                test_probs = model_dict['temp_scaler'].transform(test_logits)\n        else:\n            if mode == 'Uncalibrated':\n                val_probs = model_dict['base'].predict_proba(X_val_scaled_df)\n                test_probs = model_dict['base'].predict_proba(X_test_scaled_df)\n            elif mode == 'Isotonic':\n                val_probs = model_dict['cal_isotonic'].predict_proba(X_val_scaled_df)\n                test_probs = model_dict['cal_isotonic'].predict_proba(X_test_scaled_df)\n            else:\n                val_probs = model_dict['cal_platt'].predict_proba(X_val_scaled_df)\n                test_probs = model_dict['cal_platt'].predict_proba(X_test_scaled_df)\n                \n        val_loss = log_loss(y_val, val_probs)\n        val_acc = accuracy_score(y_val, np.argmax(val_probs, axis=1))\n        val_brier = np.mean(np.sum((val_probs - np.eye(3)[y_val])**2, axis=1))\n        val_rps = compute_rps(y_val.values, val_probs)\n        val_ece = compute_ece(y_val.values, val_probs)\n        \n        test_loss = log_loss(y_test, test_probs)\n        test_acc = accuracy_score(y_test, np.argmax(test_probs, axis=1)) \n        test_brier = np.mean(np.sum((test_probs - np.eye(3)[y_test])**2, axis=1))\n        test_rps = compute_rps(y_test.values, test_probs)\n        test_ece = compute_ece(y_test.values, test_probs)\n        \n        test_preds = np.argmax(test_probs, axis=1)\n        prec, rec, f1, _ = precision_recall_fscore_support(y_test, test_preds, average='macro')\n        \n        eval_rows.append({\n            'Model': name, 'Calibration': mode,\n            'Val LogLoss': val_loss, 'Val Acc': val_acc, 'Val Brier': val_brier, 'Val RPS': val_rps, 'Val ECE': val_ece,\n            'Test LogLoss': test_loss, 'Test Acc': test_acc, 'Test Brier': test_brier, 'Test RPS': test_rps, 'Test ECE': test_ece,\n            'Test Precision': prec, 'Test Recall': rec, 'Test F1': f1\n        })\n\ncomparison_df = pd.DataFrame(eval_rows)\ncomparison_df = comparison_df.sort_values('Val LogLoss').reset_index(drop=True)\n\ntop_models = comparison_df[comparison_df['Calibration'] != 'Uncalibrated'].head(3)\nprint('\\nTop 3 Models for Ensemble:')\ndisplay(top_models[['Model', 'Calibration', 'Val LogLoss', 'Test LogLoss']])\n\ndef predict_ensemble_proba(X_df):\n    probs_list = []\n    for _, row in top_models.iterrows():\n        m_name = row['Model']\n        c_type = row['Calibration']\n        \n        if m_name == 'Neural Network':\n            base_probs = models[m_name]['base'].predict_proba(X_df)\n            base_probs = np.clip(base_probs, 1e-15, 1 - 1e-15)\n            logits = np.log(base_probs)\n            probs = models[m_name]['temp_scaler'].transform(logits)\n        else:\n            if c_type == 'Isotonic':\n                probs = models[m_name]['cal_isotonic'].predict_proba(X_df)\n            else:\n                probs = models[m_name]['cal_platt'].predict_proba(X_df)\n        probs_list.append(probs)\n    return np.mean(probs_list, axis=0)\n\nens_val_probs = predict_ensemble_proba(X_val_scaled_df)\nens_test_probs = predict_ensemble_proba(X_test_scaled_df)\n\nens_row = {\n    'Model': 'Ensemble (Top 3)', 'Calibration': 'Weighted Average',\n    'Val LogLoss': log_loss(y_val, ens_val_probs),\n    'Val Acc': accuracy_score(y_val, np.argmax(ens_val_probs, axis=1)),\n    'Val Brier': np.mean(np.sum((ens_val_probs - np.eye(3)[y_val])**2, axis=1)),\n    'Val RPS': compute_rps(y_val.values, ens_val_probs),\n    'Val ECE': compute_ece(y_val.values, ens_val_probs),\n    'Test LogLoss': log_loss(y_test, ens_test_probs),\n    'Test Acc': accuracy_score(y_test, np.argmax(ens_test_probs, axis=1)),\n    'Test Brier': np.mean(np.sum((ens_test_probs - np.eye(3)[y_test])**2, axis=1)),\n    'Test RPS': compute_rps(y_test.values, ens_test_probs),\n    'Test ECE': compute_ece(y_test.values, ens_test_probs),\n    'Test Precision': precision_recall_fscore_support(y_test, np.argmax(ens_test_probs, axis=1), average='macro')[0],\n    'Test Recall': precision_recall_fscore_support(y_test, np.argmax(ens_test_probs, axis=1), average='macro')[1],\n    'Test F1': precision_recall_fscore_support(y_test, np.argmax(ens_test_probs, axis=1), average='macro')[2]\n}\n\ncomparison_df = pd.concat([comparison_df, pd.DataFrame([ens_row])], ignore_index=True)\ncomparison_df = comparison_df.sort_values('Val LogLoss').reset_index(drop=True)\n\ncomparison_df.to_csv(os.path.join('outputs', 'model_comparison.csv'), index=False)\nprint('Saved outputs/model_comparison.csv')\ndisplay(comparison_df.head(10))"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## 4.6 Feature Importance & SHAP Values\n\nWe output feature importances and compute SHAP values for model transparency."
